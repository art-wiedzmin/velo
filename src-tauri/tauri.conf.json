{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "velo",
  "version": "1.0.2",
  "identifier": "com.velo.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "velo",
        "width": 1100,
        "height": 720,
        "minWidth": 830,
        "minHeight": 560,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["../tools/sing-box"]
  }
}

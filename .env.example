# Optional secrets for live integration tests.
# Copy to `.env` (gitignored) and fill in. Tests that need these will skip
# silently when the variable is absent.

# Subscription URL probed by `cargo test --test live_sub`.
VELO_TEST_SUB_URL=

# VLESS profile URL used by `cargo test --test runner_e2e`.
# Spawns sing-box, opens local SOCKS5, fetches https://api.ipify.org through it.
VELO_TEST_VLESS_URL=

# Optional: path to a `sing-box` binary used by `cargo test --test singbox_validate`
# to run `sing-box check` on generated configs. Defaults to `tools/sing-box.exe`.
# VELO_SINGBOX=

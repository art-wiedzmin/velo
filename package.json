{
  "name": "velo",
  "version": "1.1.2",
  "description": "VLESS desktop client for Windows. Tauri 2 + Svelte 5 shell around a sing-box sidecar.",
  "type": "module",
  "license": "GPL-3.0-or-later",
  "author": "art-wiedzmin",
  "homepage": "https://github.com/art-wiedzmin/velo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/art-wiedzmin/velo.git"
  },
  "bugs": {
    "url": "https://github.com/art-wiedzmin/velo/issues"
  },
  "keywords": [
    "vless",
    "vmess",
    "trojan",
    "sing-box",
    "tauri",
    "svelte",
    "proxy",
    "windows"
  ],
  "scripts": {
    "postinstall": "node scripts/fetch-singbox.mjs",
    "prebuild": "node scripts/fetch-singbox.mjs",
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "tauri": "tauri",
    "build:portable": "node scripts/build-portable.mjs"
  },
  "dependencies": {
    "@fontsource/geist": "^5.2.9",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.64.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^25.9.3",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
